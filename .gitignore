# --- personal / device-specific data — never publish ---
# raw bluetooth captures (contain the config library), config backups, engineering notes
artifacts/
backups/
private/
*.btsnoop
*.json

# --- copyrighted / third-party — do not redistribute ---
# app binary, game-support database, decompiled app, repackaged app, third-party libs
*.apk
*.idsig
*.ximmr
work/
build/
tools/openssl/
tools/apktool.jar

# web UI: generated/extracted assets (vendor cover art + XIM button icons + manifest),
# the local config library, and the python venv — all regenerated locally, never published
webui/frontend/assets/
webui/data/
webui/.venv/
.venv/

# --- credentials ---
*.keystore
*.jks

# --- misc ---
__pycache__/
*.pyc
.DS_Store

# editor/session scratch and transcripts — but keep requirements.txt
*.txt
!requirements.txt
